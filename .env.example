# Local development environment for `wh`.
#
# Copy this file to `.env` (which is gitignored) and adjust as needed:
#   cp .env.example .env
#
# Variables defined here are loaded ONLY by the `make dev*` targets.
# They are NOT read by the installed `wh` binary, so your real database at
# ~/.local/share/wh/wh.db is never affected by dev settings.

# Path to the dev SQLite database. Kept inside the repo and gitignored so dev
# work never touches your production data. Defaults to ./dev.db if unset.
WH_DB=./dev.db
